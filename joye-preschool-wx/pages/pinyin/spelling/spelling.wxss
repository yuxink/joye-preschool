/* 拼读训练 */
.container {
  padding: 30rpx;
}

.tabs {
  display: flex;
  margin-bottom: 24rpx;
  gap: 10rpx;
}

.tab {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: #fff;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #64748b;
  border: 2rpx solid #e2e8f0;
}

.tab.active {
  background: #6366f1;
  color: #fff;
  border-color: #6366f1;
}

.spelling-card {
  text-align: center;
  padding: 52rpx 34rpx;
}

.parts {
  font-size: 46rpx;
  margin-bottom: 24rpx;
}

.pinyin-initial {
  color: #0284c7;
  font-weight: 700;
}

.pinyin-medial {
  color: #16a34a;
  font-weight: 700;
}

.pinyin-final {
  color: #dc2626;
  font-weight: 700;
}

.plus,
.equals {
  color: #94a3b8;
  margin: 0 8rpx;
}

.result {
  color: #6366f1;
  font-weight: 700;
}

.char {
  font-size: 72rpx;
  margin-bottom: 14rpx;
}

.hint {
  font-size: 24rpx;
  color: #64748b;
}

.tone-base {
  font-size: 60rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 24rpx;
}

.tone-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.tone-chip {
  background: #eef2ff;
  color: #3730a3;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 14rpx;
}

.tone-play-all {
  display: inline-block;
  margin-bottom: 12rpx;
  background: #dbeafe;
  color: #1d4ed8;
  border-radius: 999rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.nav-buttons {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 30rpx;
}

.btn {
  padding: 18rpx 34rpx;
  background: #fff;
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.progress {
  color: #64748b;
}

.fade-in {
  animation: fadeIn 0.28s ease;
}

.slide-in-right {
  animation: slideInRight 0.28s ease;
}

.slide-in-left {
  animation: slideInLeft 0.28s ease;
}

@keyframes fadeIn {
  from { opacity: 0.6; transform: scale(0.98); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes slideInRight {
  from { opacity: 0.7; transform: translateX(22rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes slideInLeft {
  from { opacity: 0.7; transform: translateX(-22rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.group-tabs {
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.group-tab {
  display: inline-block;
  margin-right: 12rpx;
  padding: 12rpx 20rpx;
  background: #fff;
  border: 2rpx solid #e2e8f0;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #475569;
}

.group-tab.active {
  background: #e0e7ff;
  color: #4338ca;
  border-color: #c7d2fe;
}

.tone-1 { color: #2563eb !important; }
.tone-2 { color: #16a34a !important; }
.tone-3 { color: #ea580c !important; }
.tone-4 { color: #dc2626 !important; }

.tone-word {
  display: inline-flex;
  align-items: flex-start;
  position: relative;
  margin: 0 4rpx;
}

.tone-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 24rpx;
  height: 24rpx;
  margin-left: 4rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.08);
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1;
  padding: 0 6rpx;
}

.tone-badge.mini {
  min-width: 22rpx;
  height: 22rpx;
  font-size: 16rpx;
  margin-left: 8rpx;
}
