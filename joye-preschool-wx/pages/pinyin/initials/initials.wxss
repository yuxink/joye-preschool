.container{padding:30rpx}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20rpx}.pinyin-card{background:#fff;border-radius:20rpx;padding:30rpx;text-align:center;box-shadow:0 4rpx 12rpx rgba(0,0,0,0.05)}.pinyin{font-size:48rpx;font-weight:600;margin-bottom:10rpx}.pinyin-initial{color:#4A90D9}.char{font-size:28rpx;color:#666;margin-bottom:6rpx}.type{font-size:22rpx;color:#999}