.container{padding:30rpx}.tabs{display:flex;margin-bottom:30rpx}.tab{flex:1;padding:20rpx;text-align:center;font-size:26rpx;color:#666;border-bottom:4rpx solid transparent}.tab.active{color:#FF69B4;border-bottom-color:#FF69B4}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20rpx}.pinyin-card{background:#fff;border-radius:20rpx;padding:30rpx;text-align:center;box-shadow:0 4rpx 12rpx rgba(0,0,0,0.05)}.pinyin{font-size:48rpx;font-weight:600;margin-bottom:10rpx}.pinyin-final{color:#E74C3C}.char{font-size:28rpx;color:#666}