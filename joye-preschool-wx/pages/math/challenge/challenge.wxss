.container{padding:30rpx;min-height:100vh;box-sizing:border-box}.hero{background:#eef2ff;border:2rpx solid #c7d2fe;margin-bottom:24rpx}.hero-title{font-size:38rpx;font-weight:700;color:#3730a3;margin-bottom:10rpx}.hero-subtitle{font-size:24rpx;color:#6366f1}.level-list{display:flex;flex-direction:column;gap:20rpx}.level-card{background:#fff;border-radius:22rpx;padding:28rpx;border:2rpx solid #e2e8f0}.level-head{display:flex;justify-content:space-between;align-items:center}.level-name{font-size:34rpx;font-weight:700;color:#0f172a}.level-diff{margin-top:8rpx;color:#64748b;font-size:24rpx}.lock{font-size:22rpx;color:#ef4444;background:#fee2e2;padding:8rpx 16rpx;border-radius:999rpx}.lock.on{color:#059669;background:#d1fae5}.stars{margin-top:16rpx;color:#f59e0b;font-size:36rpx;letter-spacing:6rpx}.progress-header{margin-bottom:20rpx}.progress-header text{font-size:24rpx;color:#64748b;margin-bottom:10rpx;display:block}.question-card{position:relative;background:#fff;border-radius:28rpx;padding:56rpx 36rpx;text-align:center;margin-bottom:30rpx;border:2rpx solid #e2e8f0}.question-level{color:#6366f1;font-size:24rpx;margin-bottom:14rpx}.question-text{font-size:46rpx;font-weight:700;color:#0f172a;line-height:1.4}.sound-btn{position:absolute;right:20rpx;top:20rpx;width:66rpx;height:66rpx;border-radius:50%;background:#eff6ff;display:flex;justify-content:center;align-items:center}.sound-btn image{width:36rpx;height:36rpx}.options-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18rpx;margin-bottom:30rpx}.option-btn{text-align:center;background:#fff;border:2rpx solid #e2e8f0;border-radius:18rpx;font-size:40rpx;font-weight:700;padding:30rpx}.option-btn.selected{border-color:#6366f1;background:#eef2ff}.option-btn.correct{border-color:#10b981;background:#d1fae5;color:#047857}.option-btn.wrong{border-color:#ef4444;background:#fee2e2;color:#b91c1c}.result-card{margin-top:20rpx;text-align:center}.result-title{font-size:42rpx;font-weight:700;color:#0f172a}.result-score{margin-top:12rpx;font-size:34rpx;color:#475569}.result-stars{margin-top:16rpx;font-size:62rpx;color:#f59e0b;letter-spacing:10rpx}.result-tip{margin-top:14rpx;font-size:26rpx;color:#64748b}.result-actions{margin-top:30rpx;display:flex;gap:16rpx}.result-actions .btn{flex:1}
